{
    "name": "PyLens",
    "version": "0.0.1",
    "publisher": "chris",
    "engines": {
        "vscode": "^1.74.0"
    },
    "main": "./out/extension.js",
    "activationEvents": [
        "onLanguage:python"
    ],
    "contributes": {
        "languages": [
            {
                "id": "python",
                "extension": [".py"]
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "postinstall": "python -m pip install -e src/analyzer || echo \"python dependencies could not be installed\""
    },
    "devDependencies": {
        "typescript": "^4.9.5",
        "@types/node": "^14.18.0",
        "@types/vscode": "^1.74.0"
    }
}